@page "/students/update/{id:int}"
@using Application.DTOs
@using Application.Services.StudentServices
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IStudentService StudentService
<div>
    <EditForm OnValidSubmit="EditStudentAsync" Model="student">
        <div class="form-group">
            <label for="name" >Name:</label>
            <InputText class="form-control" id="name" @bind-Value="student.Name" />
        </div>
        <div class="form-group">
            <label for="sex" >Sex:</label>
            <InputSelect id="sex" class="form-control" @bind-Value="student.Sex">
                <option value="">--- Select Sex</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
            </InputSelect>
        </div>
        <div class="form-group">
            <label for="dob" >Date Of Birth:</label>
            <InputDate id="dob" class="form-control" @bind-Value="student.DateOfBirth" />
        </div>
        <div class="form-group">
            <label for="phone" >Phone:</label>
            <InputText id="phone" class="form-control" @bind-Value="student.Phone" />
        </div>
        <div class="form-group">
            <label for="email" >Email:</label>
            <InputText id="email" class="form-control" @bind-Value="student.Email" />
        </div>

        <div class="form-group">
            <label for="regnumber">RegNumber</label>
            <InputText id="regnumber" class="form-control" @bind-Value="student.RegNumber" />
        </div>
        <div class="form-group">
            <label for="address" >Address:</label>
            <InputTextArea id="address" class="form-control" @bind-Value="student.Address" />
        </div>

        <div class="form-group">
            <label for="mothersname">Mother's Name</label>
            <InputText id="mamalove" class="form-control" @bind-Value="student.MotherName" />
        </div>

        <div class="form-group">
            <label for="fathersname">Father's Name</label>
            <InputText id="papalove" class="form-control" @bind-Value="student.FatherName" />
        </div>

        <div class="form-group">
            <label for="mothersname">Mother's Phone</label>
            <InputText id="iloveyouma" class="form-control" @bind-Value="student.MotherPhone" />
        </div>

        <div class="form-group">
            <label for="mothersname">Father's Phone</label>
            <InputText id="iloveyouma" class="form-control" @bind-Value="student.FatherPhone" />
        </div>

        
        <button type="submit" class="btn btn-primary">Update</button>
    </EditForm>
</div>
@code{
    [Parameter]
    public int Id{get;set;}
    private GetStudentDTO? existingstudent;
    private UpdateStudentDTO student = new();
    protected override async Task OnParametersSetAsync()
    {
        existingstudent= await StudentService.GetStudentByIdAsync(Id);
        if (existingstudent != null)
        {
            student.Address = existingstudent.Address;
            student.DateOfBirth = existingstudent.DateOfBirth;
            student.Email = existingstudent.Email;
            student.FatherName = existingstudent.FatherName;
            student.FatherPhone = existingstudent.FatherPhone;
            student.Id = existingstudent.Id;
            student.MotherName = existingstudent.MotherName;
            student.MotherPhone = existingstudent.MotherPhone;
            student.Name = existingstudent.Name;
            student.Phone = existingstudent.Phone;
            student.RegNumber = existingstudent.RegNumber;
            student.Sex = existingstudent.Sex;
        }
    }
    private async Task EditStudentAsync()
    {
      await  StudentService.UpdateStudentAsync(student);
        Navigation.NavigateTo("/students");
    }
}
