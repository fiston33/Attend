@using Application.Services.StudentServices
@using Application.DTOs
@inject IStudentService StudentService
@page "/Students/{id:int}"


<a href="/students" class="btn btn-secondary">Back to List</a>
<!-- Student Details Card -->
<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Student Details</h3>
        </div>
        <div class="card-body">
            @if (student != null)
            {
                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Id:</div>
                    <div class="col-md-8">@student.Id</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Name:</div>
                    <div class="col-md-8">@student.Name</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Sex:</div>
                    <div class="col-md-8">@student.Sex</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Date Of Birth:</div>
                    <div class="col-md-8">@student.DateOfBirth</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Phone:</div>
                    <div class="col-md-8">@student.Phone</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Email:</div>
                    <div class="col-md-8">@student.Email</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Reg Number:</div>
                    <div class="col-md-8">@student.RegNumber</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Address:</div>
                    <div class="col-md-8">@student.Address</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Mother's Name:</div>
                    <div class="col-md-8">@student.MotherName</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Father's Name:</div>
                    <div class="col-md-8">@student.FatherName</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Mother's Phone:</div>
                    <div class="col-md-8">@student.MotherPhone</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Father's Phone:</div>
                    <div class="col-md-8">@student.FatherPhone</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">User Added By:</div>
                    <div class="col-md-8">@student.UserAdded</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Date Added:</div>
                    <div class="col-md-8">@student.DateAdded</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Status:</div>
                    <div class="col-md-8">@student.Status</div>
                </div>



                
                
                <div class="row">
                    <div class="col text-right">
                        <a href="/students/update/@student.Id"><button class="btn btn-primary">Edit</button></a>
                        <a href="/students/delete/@student.Id"><button class="btn btn-danger">Delete</button></a>
                        <a href="#"><button class="btn btn-secondary ">Restore</button></a>
                    </div>
                </div>
            }
            else
            {
                <p>Loading student details...</p>
            }
        </div>
    </div>
</div>

<!-- Optional: Use Bootstrap for responsiveness and pleasant look -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">



@code {
    [Parameter]
    public int Id { get; set; }
    private GetStudentDTO? student;
    protected override async Task OnParametersSetAsync()
    {
        student = await StudentService.GetStudentByIdAsync(Id);
    }

    
}